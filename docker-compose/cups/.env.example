# ipp uri of the physical printer (entrypoint pings this host and
# points every preset queue at it)
PRINTER_URI=ipp://192.168.1.25/ipp/print
# queue set as system default; must match a presets/<name>.conf
DEFAULT_PRESET=photo
# web admin login at :631/admin; leave password empty to skip provisioning
CUPS_ADMIN_USER=admin
CUPS_ADMIN_PASSWORD=changeme
# drag-and-drop print page
WEBUI_PORT=8631
